# --- OpenCode Go (recommended) --------------------------------------------------------------
# Subscribe to Go and copy your API key: https://opencode.ai/docs/go/
OPENCODE_API_KEY=
NDIS_BASE_URL=https://opencode.ai/zen/go/v1
# Use an INSTRUCTION model (returns JSON directly). Avoid reasoning models like glm-5.1 for this
# task — they spend the whole token budget thinking and return empty content (finish_reason "length").
NDIS_MODEL=deepseek-v4-flash
# Confirmed working OpenCode Go model IDs (from /v1/models):
#   deepseek-v4-flash  deepseek-v4-pro  mimo-v2.5  mimo-v2.5-pro
#   kimi-k2.7-code (temp=1 only)  kimi-k2.6  glm-5.1 (reasoning, returns empty — avoid)
#   minimax-m3  qwen3.7-max  qwen3.7-plus
NDIS_MAX_TOKENS=16000
NDIS_TIMEOUT=120

# --- Wafer (drop-in alternative) ------------------------------------------------------------
# Wafer is also OpenAI-compatible. To use it instead, set NDIS_API_KEY (wins over OPENCODE_API_KEY),
# point NDIS_BASE_URL at Wafer's OpenAI-compatible base URL, and pick a Wafer model id.
# NDIS_API_KEY=
# NDIS_BASE_URL=https://api.wafer.ai/v1
# NDIS_MODEL=glm-5.1
